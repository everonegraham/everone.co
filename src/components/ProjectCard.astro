---
export interface Props {
  title: string;
  description: string;
  link: string;
  icon: string;
  status: "concept" | "live" | "archived";
}

const { title, description, link, icon, status } = Astro.props;

const statusColors = {
  "live": "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100",
  "concept": "bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-100",
  "archived": "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-100"
};

const statusText = {
  "live": "Live",
  "concept": "Concept",
  "archived": "Archived"
};
---

<a
  href={`https://${link}`}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex flex-col rounded-lg border border-skin-line bg-skin-card p-6 transition-all duration-200 hover:scale-105 hover:border-skin-accent"
>
  <div class="mb-4 flex items-center justify-between">
    <div class="text-4xl">{icon}</div>
    <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${statusColors[status]}`}>
      {statusText[status]}
    </span>
  </div>
  <h3 class="mb-2 text-xl font-semibold text-skin-base group-hover:text-skin-accent">
    {title}
  </h3>
  <p class="mb-4 text-skin-muted">{description}</p>
  <div class="mt-auto flex items-center text-skin-muted">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="mr-2 h-4 w-4"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        fill-rule="evenodd"
        d="M12.586 4.586a2 2 0 112.828 2.828l-3 3a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3-3a4 4 0 00-5.656-5.656l-1.5 1.5a1 1 0 101.414 1.414l1.5-1.5zm-5 5a2 2 0 012.828 0 1 1 0 101.414-1.414 4 4 0 00-5.656 0l-3 3a4 4 0 105.656 5.656l1.5-1.5a1 1 0 10-1.414-1.414l-1.5 1.5a2 2 0 11-2.828-2.828l3-3z"
        clip-rule="evenodd"
      />
    </svg>
    <span class="text-sm">{link}</span>
  </div>
</a> 